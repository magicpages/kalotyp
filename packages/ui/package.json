{
  "name": "@magicpages/kalotyp-ui",
  "version": "0.0.0",
  "description": "Default UI for Kalotyp — an open-source image editor for Ghost CMS.",
  "license": "MIT",
  "author": "Jannis Fedoruk-Betschki <jannis@magicpages.co>",
  "homepage": "https://github.com/magicpages/kalotyp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magicpages/kalotyp.git",
    "directory": "packages/ui"
  },
  "bugs": "https://github.com/magicpages/kalotyp/issues",
  "keywords": ["ghost", "image-editor", "ui", "canvas"],
  "type": "module",
  "sideEffects": ["*.css"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@magicpages/kalotyp-core": "workspace:*",
    "lucide": "^1.14.0"
  },
  "devDependencies": {
    "jsdom": "25.0.1",
    "typescript": "5.6.3",
    "vite": "8.0.16",
    "vitest": "2.1.5"
  }
}
