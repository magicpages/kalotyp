{
  "name": "@magicpages/kalotyp-ghost-test",
  "version": "0.0.0",
  "private": true,
  "description": "End-to-end harness: real Ghost instance + the Kalotyp build mounted via Settings → Integrations.",
  "type": "module",
  "scripts": {
    "ghost:up": "docker compose up -d --wait",
    "ghost:down": "docker compose down -v",
    "ghost:logs": "docker compose logs -f ghost",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:axe": "playwright test --project=chromium --project=mobile-chromium tests/axe.spec.ts tests/keyboard-only.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^25.9.3",
    "axe-core": "4.12.1",
    "http-server": "14.1.1",
    "typescript": "6.0.3"
  }
}
