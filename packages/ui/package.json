{
  "name": "@magicpages/kalotyp-ui",
  "version": "0.2.0",
  "description": "Default UI for Kalotyp — an open-source image editor for Ghost CMS.",
  "license": "MIT",
  "author": "Jannis Fedoruk-Betschki <jannis@magicpages.co>",
  "homepage": "https://github.com/magicpages/kalotyp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magicpages/kalotyp.git",
    "directory": "packages/ui"
  },
  "bugs": "https://github.com/magicpages/kalotyp/issues",
  "keywords": [
    "ghost",
    "image-editor",
    "ui",
    "canvas"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@magicpages/kalotyp-core": "workspace:*",
    "lucide": "^1.17.0"
  },
  "devDependencies": {
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
