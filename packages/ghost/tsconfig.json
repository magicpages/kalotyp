{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    // Typecheck-only (emit is tsconfig.build.json). Wide rootDir admits the sibling source
    // resolved via `paths`; noEmit keeps it inert.
    "noEmit": true,
    "rootDir": "../..",
    "types": ["vitest/globals"],
    "paths": {
      "@magicpages/kalotyp-core": ["../core/src/index.ts"],
      "@magicpages/kalotyp-core/*": ["../core/src/*"],
      "@magicpages/kalotyp-ui": ["../ui/src/index.ts"],
      "@magicpages/kalotyp-ui/*": ["../ui/src/*"]
    }
  },
  "include": ["src/**/*"]
}
